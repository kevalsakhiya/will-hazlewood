RUN_ENV=local                         # local | prod
LOG_LEVEL=INFO

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5433                    # 5433 to avoid clashing with a host-installed Postgres
POSTGRES_HOST_PORT=5433               # docker-compose.yml binding
POSTGRES_DB=broker_scout
POSTGRES_USER=root
POSTGRES_PASSWORD=root

# Google OAuth user credentials (used by both Sheets and Drive).
# OAUTH_CLIENT_JSON_PATH points at the client_secret JSON downloaded
# once from Google Cloud Console (APIs & Services → Credentials →
# OAuth client ID → Desktop app).
# OAUTH_TOKEN_JSON_PATH points at the file produced by running
# `poetry run python -m broker_scout.tools.oauth_setup` once.
OAUTH_CLIENT_JSON_PATH=./secrets/oauth_client.json
OAUTH_TOKEN_JSON_PATH=./secrets/oauth_token.json

# Google Sheets — monthly auto-rotation
# Each platform has ONE template spreadsheet (bootstrap step: create
# manually with header row populated, share with the service account
# email as Editor). The pipeline copies the template into a per-month
# spreadsheet inside the folder below; rotation is automatic.
GSHEET_TEMPLATE_PF_ID=
GSHEET_TEMPLATE_BAYUT_ID=
GSHEET_PF_FOLDER_ID=
GSHEET_BAYUT_FOLDER_ID=
# Comma-separated emails the rotated spreadsheet auto-shares with
# (role=reader). Empty disables auto-share — only the SA has access.
GSHEET_VIEWER_EMAILS=

# Google Drive — per-run CSV archive
# Create one folder in your Drive; the pipeline uploads one CSV per
# spider run here, named {spider}_{YYYYMMDD-HHMMSS}.csv.
GDRIVE_CSV_FOLDER_ID=

# Alerts
# ALERT_BACKEND: 'discord' or 'google_chat'. If unset, auto-detects
# whichever webhook URL is configured (Discord preferred — works on
# personal Google accounts; Google Chat requires Workspace).
ALERT_BACKEND=
DISCORD_WEBHOOK_URL=
GOOGLE_CHAT_WEBHOOK_URL=
ALERT_MIN_LEVEL=warning

# Proxy
PROXY_URL=
