RUN_ENV=local                         # local | prod
LOG_LEVEL=INFO

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=broker_scout
POSTGRES_USER=broker_scout
POSTGRES_PASSWORD=change_me

# Google service account (used by both Sheets and Drive)
SERVICE_ACCOUNT_JSON_PATH=./secrets/service_account.json

# Google Sheets — separate sheet per platform
GSHEET_PF_ID=
GSHEET_BAYUT_ID=

# Google Drive
GDRIVE_FOLDER_ID=

# Alerts
ALERT_BACKEND=google_chat
GOOGLE_CHAT_WEBHOOK_URL=
ALERT_MIN_LEVEL=warning

# Proxy
PROXY_URL=
